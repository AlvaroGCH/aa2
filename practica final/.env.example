# =============================================================================
# PLANTILLA DE VARIABLES DE ENTORNO
# =============================================================================
# Este proyecto es principalmente no-code (n8n + Claude Desktop), por lo que
# las credenciales se configuran DENTRO de n8n como "Credentials" y en el
# archivo claude_desktop_config.json (no en este .env).
#
# Este archivo documenta qué credenciales/servicios necesitarías configurar
# para reproducir el proyecto desde cero.
#
# Copia este archivo a .env solo si vas a ejecutar algún script Python de
# prueba. En condiciones normales, no hace falta.
# =============================================================================


# --- OpenAI (embeddings + modelo del agente de Telegram) ---
# Usado por: workflow de Ingesta (embeddings) y workflow de Agente Telegram (GPT-4o-mini)
# Obtener en: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx


# --- Pinecone (base vectorial del RAG) ---
# Usado por: workflows de Ingesta, Agente Telegram y MCP Server
# Obtener en: https://app.pinecone.io
PINECONE_API_KEY=pcsk_xxxxxxxxxxxxxxxxxxxxxxxx
PINECONE_INDEX_NAME=apuntes-aa2
PINECONE_ENVIRONMENT=us-east-1


# --- Telegram Bot ---
# Usado por: workflow de Agente Telegram y tool send_telegram del MCP Server
# Obtener creando un bot con @BotFather en Telegram
TELEGRAM_BOT_TOKEN=123456789:ABCxxxxxxxxxxxxxxxxxxxxxxxxxxx


# --- Supabase (memoria persistente Postgres del agente Telegram) ---
# Usado por: workflow de Agente Telegram (Postgres Chat Memory)
# Obtener en: https://supabase.com
SUPABASE_HOST=db.xxxxxxxxxxxx.supabase.co
SUPABASE_PORT=5432
SUPABASE_DATABASE=postgres
SUPABASE_USER=postgres
SUPABASE_PASSWORD=xxxxxxxxxxxxxxxxxxxx


# --- Anthropic (Claude Desktop como cliente MCP) ---
# Usado por: Claude Desktop (no por n8n)
# La clave se configura dentro de Claude Desktop, no aquí. Solo se documenta.
# Obtener en: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx


# --- URL del MCP Server (n8n) ---
# Endpoint que expone el workflow MCP Server Trigger
# Se configura en claude_desktop_config.json
N8N_MCP_SERVER_URL=http://localhost:5678/mcp/xxxxxxxxxxxx
