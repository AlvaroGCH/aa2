# =============================================================================
# PLANTILLA DE VARIABLES DE ENTORNO
# =============================================================================
# Este proyecto es principalmente no-code (n8n + Claude Desktop), por lo que
# las credenciales se configuran DENTRO de n8n como "Credentials" y en el
# archivo claude_desktop_config.json (no en este .env).
#
# Este archivo documenta qué credenciales/servicios necesitarías configurar
# para reproducir el proyecto desde cero. Los valores aquí son plantillas
# (NO credenciales reales).
# =============================================================================


# --- OpenAI (embeddings + modelo del agente de Telegram) ---
# Usado por: workflow de Ingesta (text-embedding-3-small) y
#            workflow de Agente Telegram (gpt-4o-mini)
# Nota: en este proyecto se usan los créditos gratuitos de n8n, pero también
#       puedes usar tu propia clave.
# Obtener en: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx


# --- Pinecone (base vectorial del RAG) ---
# Usado por: workflows de Ingesta, Agente Telegram y MCP Server
# Configuración del índice:
#   - Dimensiones: 1536 (compatible con text-embedding-3-small)
#   - Métrica: cosine
#   - Cloud: AWS / us-east-1 (free tier)
#   - Capacity mode: serverless
# Obtener en: https://app.pinecone.io
PINECONE_API_KEY=pcsk_xxxxxxxxxxxxxxxxxxxxxxxx
PINECONE_INDEX_NAME=asistente-tfg
PINECONE_ENVIRONMENT=us-east-1


# --- Telegram Bot ---
# Usado por: workflow de Agente Telegram (Telegram Trigger + Send Message)
#            y tool send_telegram_message del MCP Server
# Obtener creando un bot con @BotFather en Telegram
TELEGRAM_BOT_TOKEN=123456789:ABCxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Chat ID fijo al que el MCP Server envía los mensajes (el del propietario)
# Obtener escribiendo a @userinfobot en Telegram
TELEGRAM_OWNER_CHAT_ID=123456789


# --- Supabase (memoria persistente Postgres del agente Telegram) ---
# Usado por: workflow de Agente Telegram (Postgres Chat Memory)
#
# IMPORTANTE: n8n Cloud NO tiene conectividad IPv6, por lo que la conexión
# directa (db.<projectref>.supabase.co:5432) falla con ENETUNREACH.
# Hay que usar el SESSION POOLER (IPv4) en su lugar:
#
#   Host: aws-0-<REGION>.pooler.supabase.com   (ej: eu-central-1)
#   User: postgres.<PROJECTREF>                (nota el sufijo con el project ref)
#   Port: 5432  (Session mode) o 6543 (Transaction mode)
#
# Obtener en: Supabase Dashboard → tu proyecto → Connect → Direct → Session pooler
SUPABASE_POOLER_HOST=aws-0-eu-central-1.pooler.supabase.com
SUPABASE_POOLER_PORT=5432
SUPABASE_DATABASE=postgres
SUPABASE_USER=postgres.xxxxxxxxxxxxxxxxxxxx
SUPABASE_PASSWORD=xxxxxxxxxxxxxxxxxxxx


# --- Google Drive ---
# Usado por: workflow de Ingesta para leer los .txt del TFG
# La credencial en n8n se configura vía OAuth2 (no hay variables aquí)
# Solo necesitas apuntar al ID de la carpeta de Drive:
GOOGLE_DRIVE_FOLDER_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx


# --- Anthropic (Claude Desktop como cliente MCP) ---
# La clave se configura DENTRO de Claude Desktop (no en este .env ni en n8n).
# Solo se documenta aquí para que sepas que necesitas una cuenta.
# Obtener en: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx


# --- URL del MCP Server (n8n Cloud) ---
# Endpoint que expone el workflow "RAG - MCP Server" (Production URL)
# Se configura en claude_desktop_config.json (argumento de mcp-remote)
N8N_MCP_SERVER_URL=https://<tu-instancia>.app.n8n.cloud/mcp/<uuid-del-path>
